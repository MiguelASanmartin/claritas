FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS base
WORKDIR /app
EXPOSE 80
EXPOSE 443

FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copy project files for restore (layer caching)
COPY ["TMS.Web.API/TMS.Web.API.csproj", "TMS.Web.API/"]
COPY ["TMS.Application/TMS.Application.csproj", "TMS.Application/"]
COPY ["TMS.Domain/TMS.Domain.csproj", "TMS.Domain/"]
COPY ["TMS.Infrastructure/TMS.Infrastructure.csproj", "TMS.Infrastructure/"]

# Restore dependencies
RUN dotnet restore "TMS.Web.API/TMS.Web.API.csproj"

# Copy everything else and build
COPY . .
WORKDIR "/src/TMS.Web.API"
RUN dotnet build "TMS.Web.API.csproj" -c Release -o /app/build

# Publish the app
RUN dotnet publish "TMS.Web.API.csproj" -c Release -o /app/publish /p:UseAppHost=false

# Final runtime image
FROM base AS final
WORKDIR /app
COPY --from=build /app/publish .
ENTRYPOINT ["dotnet", "TMS.Web.API.dll"]